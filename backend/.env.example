NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/baptist_church_onitiri_admin

# Admin auth (placeholder). If empty, /admin routes are not protected.
ADMIN_TOKEN=change_me

# Used to build public URLs for uploaded files.
# If empty, the server uses req.protocol + req.host.
BASE_URL=http://localhost:4000

# CORS: "*" or a comma-separated list of origins
CORS_ORIGIN=*

# Optional: path to your frontend seed file (JSON) containing default items.
# If empty, backend uses src/defaults/defaultData.json
DEFAULT_DATA_FILE=

# Optional: where multer stores uploaded files
UPLOAD_DIR=uploads

# Existing keys (if you already use Brevo elsewhere in this backend)
BREVO_API_KEY=your_brevo_api_key
BREVO_LIST_ID=3

